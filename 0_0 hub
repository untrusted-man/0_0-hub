local function visCheck(p)
    local root = getRoot(p)
    if not root then return false end
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local ignore = {}
    if lp.Character then table.insert(ignore, lp.Character) end
    if getChar(p) then table.insert(ignore, getChar(p)) end
    rp.FilterDescendantsInstances = ignore
    local origin = cam.CFrame.Position
    local result = workspace:Raycast(origin, root.Position - origin, rp)
    return result == nil
end

local function w2s(pos)
    local sp = cam:WorldToViewportPoint(pos)
    local onScreen = sp.Z > 0
        and sp.X >= -100 and sp.X <= cam.ViewportSize.X + 100
        and sp.Y >= -100 and sp.Y <= cam.ViewportSize.Y + 100
    return Vector2.new(sp.X, sp.Y), onScreen
end

local function w2sStrict(pos)
    local sp = cam:WorldToViewportPoint(pos)
    local onScreen = sp.Z > 0
        and sp.X >= 0 and sp.X <= cam.ViewportSize.X
        and sp.Y >= 0 and sp.Y <= cam.ViewportSize.Y
    return Vector2.new(sp.X, sp.Y), onScreen
end

local function getTarget()
    local best, bestDist = nil, cfg.FOV
    local mp = UIS:GetMouseLocation()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if cfg.TeamCheck and sameTeam(p) then continue end
        if not isAlive(p) then continue end
        local c = getChar(p)
        if not c then continue end
        local part = c:FindFirstChild(cfg.HitPart) or c:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        if cfg.WallCheck and not visCheck(p) then continue end
        local sp, onScreen = w2s(part.Position)
        if not onScreen then continue end
        local d = (sp - mp).Magnitude
        if d < bestDist then bestDist = d; best = p end
    end
    return best
end

