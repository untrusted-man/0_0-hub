local function clearNotifications()
    if not NotificationContainer then
        return
    end
    for _, child in ipairs(NotificationContainer:GetChildren()) do
        if not child:IsA("UIListLayout") then
            child:Destroy()
        end
    end
end

function showNotification(message, notificationType)
    table.insert(HubState.Notifications, {
        Message = message,
        Type = notificationType or "info",
        Time = os.clock(),
    })
    while #HubState.Notifications > 8 do
        table.remove(HubState.Notifications, 1)
    end
    if not ensureNotificationUI() then
        return
    end

    local color = Theme.Accent
    if notificationType == "success" then
        color = Theme.Success
    elseif notificationType == "error" then
        color = Theme.Danger
    elseif notificationType == "warning" then
        color = Theme.Warning
    end

    local toast = Instance.new("Frame")
    toast.Size = UDim2.fromOffset(340, 68)
    toast.Position = UDim2.new(1, 36, 0, 0)
    toast.BackgroundColor3 = Theme.Primary
    toast.BorderSizePixel = 0
    toast.Parent = NotificationContainer
    Instance.new("UICorner", toast).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke")
    stroke.Color = Theme.Border
    stroke.Transparency = 0.15
    stroke.Thickness = 1
    stroke.Parent = toast

    local accent = Instance.new("Frame")
    accent.Size = UDim2.new(0, 3, 1, -16)
    accent.Position = UDim2.fromOffset(8, 8)
    accent.BackgroundColor3 = color
    accent.BorderSizePixel = 0
    accent.Parent = toast
    Instance.new("UICorner", accent).CornerRadius = UDim.new(1, 0)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -34, 1, -18)
    label.Position = UDim2.fromOffset(24, 9)
    label.BackgroundTransparency = 1
    label.Text = tostring(message)
    label.Font = Enum.Font.GothamSemibold
    label.TextSize = 13
    label.TextColor3 = Theme.Text
    label.TextWrapped = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.Parent = toast

    safeTween(toast, TweenInfo.new(0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0),
    })
    task.delay(4.25, function()
        if toast.Parent then
            safeTween(toast, TweenInfo.new(0.24, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
                Position = UDim2.new(1, 36, 0, 0),
                BackgroundTransparency = 1,
            })
            task.wait(0.25)
            if toast.Parent then
                toast:Destroy()
            end
        end
    end)
end

