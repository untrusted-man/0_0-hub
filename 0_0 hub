table.insert(HubState.Connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then
        return
    end
    if input.KeyCode == HubState.Hotkeys.ToggleHub then
        if toggleHub then
            toggleHub(not HubState.Visible)
        end
    elseif input.KeyCode == HubState.Hotkeys.EmergencyHide then
        if toggleHub then
            toggleHub(false)
            showNotification(tr("emergency_hidden"), "info")
        end
    elseif input.KeyCode == HubState.Hotkeys.QuickExecute then
        local recent = HubState.ScriptHistory[#HubState.ScriptHistory]
        if not recent then
            showNotification(tr("no_history"), "warning")
            return
        end
        for _, script in ipairs(ScriptLibrary) do
            if script.name == recent then
                local nextState = script.isToggle and not HubState.ActiveScripts[script.name] or false
                safeExecute(script.func, script.name, nextState)
                showNotification(tr("quick_executed", tr(script.name)), "info")
                break
            end
        end
    end
end))

local function initializeHub()
    local currentGui = getPlayerGui()
    if not currentGui then
        return
    end
    for _, name in ipairs({"PhantomHub", "HubLoadingScreen", "ZeroZeroNotifications"}) do
        local existing = currentGui:FindFirstChild(name)
        if existing then
            existing:Destroy()
        end
    end
    pcall(function()
        local coreGui = game:GetService("CoreGui")
        local existingLoader = coreGui:FindFirstChild("HubLoadingScreen")
        if existingLoader then
            existingLoader:Destroy()
        end
    end)

    local loadingFinished = createLoadingScreen()
    local loadingConnection
    loadingConnection = loadingFinished:Connect(function()
        if loadingConnection then
            loadingConnection:Disconnect()
        end
        hubGui, toggleHub = createMainUI()
        hubGui.Parent = currentGui
        toggleHub(true)
        showNotification(tr("welcome_notification", HubState.Hotkeys.ToggleHub.Name), "success")
    end)
end

local function cleanupRuntime()
    for _, script in ipairs(ScriptLibrary) do
        if script.isToggle and HubState.ActiveScripts[script.name] then
            pcall(script.func, false)
        end
    end
    for _, connection in ipairs(HubState.Connections) do
        if connection and connection.Connected then
            connection:Disconnect()
        end
    end
    HubState.Connections = {}
    HubState.Visible = false
    local currentGui = getPlayerGui()
    if currentGui then
        for _, name in ipairs({"PhantomHub", "HubLoadingScreen", "ZeroZeroNotifications"}) do
            local existing = currentGui:FindFirstChild(name)
            if existing then
                existing:Destroy()
            end
        end
    end
    pcall(function()
        local coreLoader = game:GetService("CoreGui"):FindFirstChild("HubLoadingScreen")
        if coreLoader then
            coreLoader:Destroy()
        end
    end)
    if blurEffect and blurEffect.Parent then
        blurEffect:Destroy()
    end
end

GlobalEnvironment.ZeroZeroHubRuntime = {Cleanup = cleanupRuntime}

