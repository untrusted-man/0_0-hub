local function ProcessSingleMaterial(instance)
    if instance:IsA("BasePart") then
        if instance.Material == Enum.Material.Plastic or instance.Material == Enum.Material.SmoothPlastic then
            instance.Reflectance = math_clamp(instance.Reflectance + ENGINE_CONFIG.Materials.ReflectionBoost, 0, 1)
        elseif instance.Material == Enum.Material.Metal then
            instance.Reflectance = math_clamp(instance.Reflectance + ENGINE_CONFIG.Materials.ReflectionBoost + 0.2, 0.5, 1)
        elseif instance.Material == Enum.Material.Water then
            instance.Transparency = 0.3
            instance.Reflectance = 1
        elseif instance.Material == Enum.Material.Glass then
            instance.Reflectance = 1
        end
        if ENGINE_CONFIG.Materials.FakeSubsurfaceScattering then
            local h, s, v = Color3_toHSV(instance.Color)
            if h > 0.02 and h < 0.18 and s > 0.25 then
                if not instance:FindFirstChild("SSS_Fake") and instance.Size.Magnitude > 1.5 then
                    local sssLight = Instance.new("PointLight")
                    sssLight.Name = "SSS_Fake"
                    sssLight.Color = Color3_fromHSV(h, math_clamp(s * ENGINE_CONFIG.ColorVibrance.GlowMultiplier, 0, 1), v)
                    sssLight.Range = instance.Size.Magnitude * 2.5
                    sssLight.Brightness = 0.4
                    sssLight.Shadows = false
                    sssLight.Parent = instance
                end
            end
        end
    end
end

