            RenderNodes.Atmosphere.Color = OriginalAtmosphereColor
            RenderNodes.Atmosphere.Decay = OriginalAtmosphereDecay
            RenderNodes.Atmosphere.Density = 0.3
        else
            RenderNodes.Atmosphere.Density = 0
        end
    end
end

