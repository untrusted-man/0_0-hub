        func = function(state)
            local Players = game:GetService("Players")
            local RunService = game:GetService("RunService")
            local localPlayer = Players.LocalPlayer
            local alertCooldowns = {}
            local function canAlert(key, cooldown)
                local now = os.clock()
                if not alertCooldowns[key] or now - alertCooldowns[key] >= cooldown then
                    alertCooldowns[key] = now
                    return true
                end
                return false
            end

            if state then
                -- Connections table
                local connections = {}

                -- Join notification
                connections.playerAdded = Players.PlayerAdded:Connect(function(p)
                    showNotification(tr("player_joined", p.Name), "info")
                end)

                -- Proximity + facing detector
                connections.heartbeat = RunService.Heartbeat:Connect(function()
                    local char = localPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then return end

                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local otherHRP = p.Character.HumanoidRootPart
                            local distance = (otherHRP.Position - hrp.Position).Magnitude

                            -- Proximity alert
                            if distance < 50 and canAlert("near_" .. p.UserId, 10) then
                                showNotification(tr("player_near", p.Name, math.floor(distance)), "info")
                            end

                            -- Facing-towards-you alert (simple dot check)
                            local dirToYou = (hrp.Position - otherHRP.Position).Unit
                            local look = otherHRP.CFrame.LookVector
                            local dot = look:Dot(dirToYou)
                            if dot > 0.8 and distance < 80 and canAlert("look_" .. p.UserId, 10) then
                                showNotification(tr("player_looking", p.Name), "info")
                            end
                        end
                    end
                end)

                HubState.ActiveScripts.player_notifier = connections
                showNotification(tr("notifier_enabled"), "success")
                return true
            else
                local connections = HubState.ActiveScripts.player_notifier
                if connections then
                    for _, conn in pairs(connections) do
                        if conn.Disconnect then
                            conn:Disconnect()
                        end
                    end
                end
                HubState.ActiveScripts.player_notifier = nil
                showNotification(tr("notifier_disabled"), "info")
                return true
            end
        end
