local spinAng = 0

RunService.RenderStepped:Connect(function()
    if cfg.Spinbot then
        local root = getRoot(lp)
        if root then
            spinAng = (spinAng + cfg.SpinSpd) % 360
            root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(spinAng), 0)
        end
    end

    local mp = UIS:GetMouseLocation()

    if fovCircle then
        fovCircle.Position = mp
        fovCircle.Radius   = cfg.FOV
        fovCircle.Visible  = cfg.Aimbot and cfg.ShowFOV and not cfg.SilentAim
    end

    local target = cfg.Aimbot and getTarget() or nil
    silentTarget = cfg.SilentAim and target or nil

    if cfg.Aimbot and cfg.AimbotHeld and not cfg.SilentAim and target then
        local c    = getChar(target)
        local part = c and (c:FindFirstChild(cfg.HitPart) or c:FindFirstChild("HumanoidRootPart"))
        if part then
            local sp, onScreen = w2s(part.Position)
            if onScreen then
                local jx = cfg.AntiDetect and (math.random()-0.5)*0.5 or 0
                local jy = cfg.AntiDetect and (math.random()-0.5)*0.5 or 0
                local sm = math.clamp(cfg.Smooth * (cfg.AntiDetect and (0.85+math.random()*0.3) or 1), 0.01, 1)
                local dx = (sp.X + jx - mp.X) * sm
                local dy = (sp.Y + jy - mp.Y) * sm
                moveMouse(dx, dy)
            end
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        local e = esps[player]
        if not e then continue end

        local show = cfg.ESP and not (cfg.ESPTeam and sameTeam(player))
        local c    = getChar(player)
        local h    = getHum(player)
        local root = getRoot(player)

        if not show or not c or not h or not root or h.Health <= 0 then
            hideESP(player); continue
        end

        local head         = c:FindFirstChild("Head") or root
        local hSP, hOnScr = w2sStrict(head.Position + Vector3.new(0, 0.65, 0))
        local fSP          = w2sStrict(root.Position - Vector3.new(0, 3.1, 0))
        local rSP          = w2sStrict(root.Position)

        if not hOnScr then hideESP(player); continue end

        local bH = math.abs(hSP.Y - fSP.Y)
        local bW = bH * 0.55
        local bX = rSP.X - bW / 2
        local bY = hSP.Y

        if cfg.BoxESP and e.B then
            pcall(function()
                e.BO.Visible=true; e.BO.Size=Vector2.new(bW+4,bH+4); e.BO.Position=Vector2.new(bX-2,bY-2)
                e.B.Visible=true; e.B.Color=cfg.ESPColor; e.B.Size=Vector2.new(bW,bH); e.B.Position=Vector2.new(bX,bY)
            end)
        else pcall(function() e.BO.Visible=false; e.B.Visible=false end) end

        if cfg.HealthESP and e.HF then
            pcall(function()
                local ratio = math.clamp(h.Health/math.max(h.MaxHealth,1), 0, 1)
                local bw2, bx2 = 5, bX-8
                e.HB.Visible=true; e.HB.Size=Vector2.new(bw2,bH); e.HB.Position=Vector2.new(bx2,bY)
                e.HF.Visible=true
                e.HF.Color=Color3.fromRGB(math.floor(255*(1-ratio)), math.floor(255*ratio), 0)
                e.HF.Size=Vector2.new(bw2, bH*ratio)
                e.HF.Position=Vector2.new(bx2, bY+bH*(1-ratio))
                e.HT.Visible=true
                e.HT.Text=math.floor(h.Health).."hp"
                e.HT.Position=Vector2.new(rSP.X, fSP.Y+14)
            end)
        else pcall(function() e.HB.Visible=false; e.HF.Visible=false; e.HT.Visible=false end) end

        if cfg.NameESP and e.N then
            pcall(function()
                e.N.Visible=true; e.N.Text=player.DisplayName; e.N.Position=Vector2.new(rSP.X, bY-20)
            end)
        else pcall(function() e.N.Visible=false end) end

        if cfg.DistESP and e.D then
            pcall(function()
                local dist = math.floor((root.Position-cam.CFrame.Position).Magnitude)
                e.D.Visible=true; e.D.Text="["..dist.."m]"; e.D.Position=Vector2.new(rSP.X, fSP.Y+2)
            end)
        else pcall(function() e.D.Visible=false end) end

        if cfg.Tracers and e.T then
            pcall(function()
                local from = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y)
                e.TO.Visible=true; e.TO.From=from; e.TO.To=rSP
                e.T.Visible=true; e.T.Color=cfg.ESPColor; e.T.From=from; e.T.To=rSP
            end)
        else pcall(function() e.T.Visible=false; e.TO.Visible=false end) end
    end
end)

