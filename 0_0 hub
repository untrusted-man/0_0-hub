    func = function()
        local HttpService = game:GetService("HttpService")
        local TeleportService = game:GetService("TeleportService")
        local gameId = game.PlaceId

        local bestServer = nil
        local nextCursor = ""
        local scans = 0

        showNotification(tr("scanner_searching"), "info")

        repeat
            scans += 1
            local url = "https://games.roblox.com/v1/games/"..gameId.."/servers/Public?limit=100&cursor="..nextCursor
            local success, data = pcall(function()
                return HttpService:JSONDecode(game:HttpGet(url))
            end)

            if success and data and data.data then
                for _, server in ipairs(data.data) do
                    
                    if server.id ~= game.JobId and server.ping and server.playing then
                        local fill = server.playing / server.maxPlayers

                        if fill >= 0.40 and fill <= 0.85 and server.ping <= 140 then
                            if not bestServer or server.ping < bestServer.ping then
                                bestServer = server
                            end
                        end
                    end

                end

                nextCursor = data.nextPageCursor or ""
            else
                break
            end

        until nextCursor == "" or scans >= 4

        if bestServer then
            showNotification(tr("joining_server", bestServer.ping, bestServer.playing, bestServer.maxPlayers), "success")
            TeleportService:TeleportToPlaceInstance(gameId, bestServer.id, Players.LocalPlayer)
        else
            showNotification(tr("no_server_found"), "error")
        end

        return true
    end
