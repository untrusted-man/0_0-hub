            local function fastStrongTeleport(targetPos)
                local char = player.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local root = char.HumanoidRootPart

                local startPos = root.Position
                local distance = (targetPos - startPos).Magnitude
                if distance < 8 then
                    root.CFrame = CFrame.new(targetPos + Vector3.new(0, 6, 0))
                    task.wait(0.05)
                    root.CFrame = CFrame.new(targetPos)
                    return
                end

                local originalTrans = {}
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and part.Transparency < 1 then
                        originalTrans[part] = part.Transparency
                        part.Transparency = 0.65
                    end
                end

                local direction = (targetPos - startPos).Unit
                local maxStep = 11.5
                local steps = math.ceil(distance / maxStep)
                local stepDist = distance / steps

                for i = 1, steps do
                    local nextPos = startPos + direction * stepDist * i

                    local noise = Vector3.new(
                        math.random(-25, 25) / 70,
                        math.random(-12, 18) / 90,
                        math.random(-25, 25) / 70
                    )

                    root.CFrame = CFrame.new(nextPos + noise)
                    root.AssemblyLinearVelocity = direction * 32 + Vector3.new(0, math.random(-6, 8), 0)

                    task.wait(0.006 + math.random(1, 5) / 600)
                end

                root.AssemblyLinearVelocity = Vector3.zero
                root.CFrame = CFrame.new(targetPos + Vector3.new(0, 9, 0))
                task.wait(0.05)
                root.CFrame = CFrame.new(targetPos + Vector3.new(0, 4, 0))
                task.wait(0.03)
                root.CFrame = CFrame.new(targetPos)

                root.AssemblyLinearVelocity = Vector3.new(0, 18, 0)
                task.wait(0.07)
                root.AssemblyLinearVelocity = Vector3.zero

                for part, trans in pairs(originalTrans) do
                    if part and part.Parent then
                        part.Transparency = trans
                    end
                end
