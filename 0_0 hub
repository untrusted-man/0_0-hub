local LastCameraCFrame = Camera.CFrame
local CurrentExposure = 0
local TargetExposure = 0

local function CalculateLuminance(color)
    return 0.2126 * color.R + 0.7152 * color.G + 0.0722 * color.B
end

local function UpdateDynamicExposure(dt)
    if not ENGINE_CONFIG.DynamicExposure.Enabled or not ENGINE_CONFIG.MasterSwitch.Enabled then
        Lighting.ExposureCompensation = 0
        return
    end
    if LocalPlayer.Character then
        GlobalRaycastParams.FilterDescendantsInstances = {LocalPlayer.Character, Workspace.CurrentCamera}
    end
    local ray = Camera:ViewportPointToRay(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local result = Workspace:Raycast(ray.Origin, ray.Direction * 600, GlobalRaycastParams)
    local sampleLuminance = 0.5
    if result and result.Instance then
        sampleLuminance = CalculateLuminance(result.Instance.Color)
        local skyCheck = Workspace:Raycast(result.Position, Vector3.new(0, 1500, 0), GlobalRaycastParams)
        if not skyCheck then
            sampleLuminance = math_clamp(sampleLuminance * 1.5, 0, 1)
        end
    else
        sampleLuminance = 1.0
    end
    TargetExposure = math_clamp((0.5 - sampleLuminance) * 4, ENGINE_CONFIG.DynamicExposure.MinExposure, ENGINE_CONFIG.DynamicExposure.MaxExposure)
    CurrentExposure = CurrentExposure + (TargetExposure - CurrentExposure) * dt * ENGINE_CONFIG.DynamicExposure.AdaptationSpeed
    Lighting.ExposureCompensation = CurrentExposure
end

local function UpdateCinematicCamera(dt)
    if not ENGINE_CONFIG.MasterSwitch.Enabled then
        RenderNodes.DoF.FocusDistance = 300
        RenderNodes.MotionBlur.Size = 0
        LastCameraCFrame = Camera.CFrame
        return
    end
    local ray = Camera:ViewportPointToRay(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local result = Workspace:Raycast(ray.Origin, ray.Direction * 300, GlobalRaycastParams)
    local targetFocusDistance = result and (result.Position - Camera.CFrame.Position).Magnitude or 300
    RenderNodes.DoF.FocusDistance = RenderNodes.DoF.FocusDistance + (targetFocusDistance - RenderNodes.DoF.FocusDistance) * dt * 6
    if ENGINE_CONFIG.Motion.MotionBlurSimulation and ENGINE_CONFIG.Motion.BlurScale > 0.1 then
        local currentCFrame = Camera.CFrame
        local _, _, _, r00, r01, r02, r10, r11, r12, r20, r21, r22 = LastCameraCFrame:components()
        local _, _, _, cr00, cr01, cr02, cr10, cr11, cr12, cr20, cr21, cr22 = currentCFrame:components()
        local deltaRot = math_abs(r00-cr00) + math_abs(r11-cr11) + math_abs(r22-cr22)
        local rawBlur = deltaRot * 150 * (ENGINE_CONFIG.Motion.BlurScale / 20)
        local targetBlur = math_clamp(rawBlur, 0, ENGINE_CONFIG.Motion.BlurScale)
        RenderNodes.MotionBlur.Size = RenderNodes.MotionBlur.Size + (targetBlur - RenderNodes.MotionBlur.Size) * dt * 18
        if RenderNodes.MotionBlur.Size > ENGINE_CONFIG.Motion.BlurScale then
            RenderNodes.MotionBlur.Size = ENGINE_CONFIG.Motion.BlurScale
        end
        LastCameraCFrame = currentCFrame
    else
        RenderNodes.MotionBlur.Size = 0
        LastCameraCFrame = Camera.CFrame
    end
end

local GINodes = table.create(24)
local MAX_GI_NODES = 24

local function InitializeGI()
    if not ENGINE_CONFIG.PathTracingFake.EnableGI then return end
    local giFolder = Instance.new("Folder")
    giFolder.Name = "LumenLite_GI_Cache"
    giFolder.Parent = Workspace.CurrentCamera
    for i = 1, MAX_GI_NODES do
        local part = Instance.new("Part")
        part.Size = Vector3.new(0.05, 0.05, 0.05)
        part.Transparency = 1
        part.Anchored = true
        part.CanCollide = false
        part.CastShadow = false
        part.Parent = giFolder
        local light = Instance.new("PointLight")
        light.Brightness = 0
        light.Range = ENGINE_CONFIG.PathTracingFake.GIRadius
        light.Shadows = true
        light.Parent = part
        GINodes[i] = {Part = part, Light = light}
    end
end

local frameCounter = 0
local function UpdateGI()
    if not ENGINE_CONFIG.PathTracingFake.EnableGI or not ENGINE_CONFIG.MasterSwitch.Enabled then
        for i = 1, MAX_GI_NODES do
            if GINodes[i] then GINodes[i].Light.Brightness = 0 end
        end
        return
    end
    frameCounter = frameCounter + 1
    local nodeIndex = (frameCounter % MAX_GI_NODES) + 1
    local node = GINodes[nodeIndex]
    local screenX = Halton(frameCounter, 2) * Camera.ViewportSize.X
    local screenY = Halton(frameCounter, 3) * Camera.ViewportSize.Y
    local ray = Camera:ViewportPointToRay(screenX, screenY)
    local result = Workspace:Raycast(ray.Origin, ray.Direction * 150, GlobalRaycastParams)
    if result and result.Instance then
        node.Part.Position = result.Position + (result.Normal * 2.0)
        local h, s, v = Color3_toHSV(result.Instance.Color)
        node.Light.Color = Color3_fromHSV(h, math_clamp(s * ENGINE_CONFIG.ColorVibrance.GlowMultiplier, 0, 1), v)
        local sunDir = Lighting:GetSunDirection()
        local sunCheck = Workspace:Raycast(result.Position, sunDir * 800, GlobalRaycastParams)
        local distanceAttenuation = math_clamp(1 - (result.Distance / 150), 0.2, 1)
        if not sunCheck then
            node.Light.Brightness = ENGINE_CONFIG.PathTracingFake.Intensity * (result.Instance.Reflectance + 0.6) * distanceAttenuation
        else
            node.Light.Brightness = (ENGINE_CONFIG.PathTracingFake.Intensity * 0.15) * distanceAttenuation
        end
    else
        node.Light.Brightness = 0
    end
end

local function ToggleEngineState()
