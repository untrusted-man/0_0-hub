    button.Text = ""
    button.Parent = parent
    addCorner(button, options.Radius or 7)
    local stroke = addStroke(button, options.StrokeColor or Theme.Border, options.StrokeTransparency or 0.25)
    if label then
        bindText(button, label)
    end
    button.MouseEnter:Connect(function()
        playUISound("hover")
        safeTween(button, TweenInfo.new(0.16, Enum.EasingStyle.Quad), {
            BackgroundTransparency = math.clamp((options.BackgroundTransparency or 0) + 0.08, 0, 0.35),
        })
        safeTween(stroke, TweenInfo.new(0.16), {Transparency = 0})
    end)
    button.MouseLeave:Connect(function()
        safeTween(button, TweenInfo.new(0.16, Enum.EasingStyle.Quad), {
            BackgroundTransparency = options.BackgroundTransparency or 0,
        })
        safeTween(stroke, TweenInfo.new(0.16), {Transparency = options.StrokeTransparency or 0.25})
    end)
    button.MouseButton1Click:Connect(function()
        playUISound("click")
    end)
    return button, stroke
end

