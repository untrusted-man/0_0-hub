local function setupSilentAim()
    pcall(function()
        if not has(getrawmetatable) or not has(setreadonly) then return end
        local mt = getrawmetatable(cam)
        setreadonly(mt, false)
        local oldIndex = mt.__index
        local function hook(self, key)
            if cfg.SilentAim and cfg.Aimbot and key == "CFrame" then
                local target = silentTarget
                if target then
                    local c = getChar(target)
                    local part = c and (c:FindFirstChild(cfg.HitPart) or c:FindFirstChild("HumanoidRootPart"))
                    if part then
                        local pos = rawget(self, "CFrame") and rawget(self, "CFrame").Position or oldIndex(self, "CFrame").Position
                        local dir = (part.Position - pos).Unit
                        return CFrame.new(pos, pos + dir)
                    end
                end
            end
            return oldIndex(self, key)
        end
        mt.__index = has(newcclosure) and newcclosure(hook) or hook
        setreadonly(mt, true)
    end)
end
