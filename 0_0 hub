local LocalizedElements = {}
local LanguageChangedCallbacks = {}

function tr(key, ...)
    local language = Languages[HubState.CurrentLanguage] or Languages.en
    local value = language[key] or Languages.en[key] or key
    if select("#", ...) > 0 then
        local ok, formatted = pcall(string.format, value, ...)
        if ok then
            return formatted
        end
    end
    return value
end

local function resolveLocalized(value)
    if type(value) == "function" then
        return value()
    end
    return tr(value)
end

local function refreshLocalizedRecord(record)
    if record.Object then
        pcall(function()
            record.Object[record.Property] = resolveLocalized(record.Value)
        end)
    end
end

function bindLocalized(object, property, keyOrResolver)
    local record = {Object = object, Property = property, Value = keyOrResolver}
    table.insert(LocalizedElements, record)
    refreshLocalizedRecord(record)
    return record
end

function bindText(object, keyOrResolver)
    return bindLocalized(object, "Text", keyOrResolver)
end

function bindPlaceholder(object, keyOrResolver)
    return bindLocalized(object, "PlaceholderText", keyOrResolver)
end

local function refreshLocalization(runCallbacks)
    for index = #LocalizedElements, 1, -1 do
        local record = LocalizedElements[index]
        if not record.Object or not record.Object.Parent then
            table.remove(LocalizedElements, index)
        else
            refreshLocalizedRecord(record)
        end
    end
    if runCallbacks then
        for _, callback in ipairs(LanguageChangedCallbacks) do
            pcall(callback)
        end
    end
end

local function onLanguageChanged(callback)
    table.insert(LanguageChangedCallbacks, callback)
end

function safeWait(seconds)
    return task.wait(seconds or 0.03)
end

function safeTween(object, tweenInfo, properties)
    local ok, tween = pcall(function()
        return TweenService:Create(object, tweenInfo, properties)
    end)
    if ok and tween then
        tween:Play()
        return tween
    end
    for property, value in pairs(properties) do
        pcall(function()
            object[property] = value
        end)
    end
    return nil
end

local function playUISound(kind)
    if not HubState.Settings.Sounds or not SoundService then
        return
    end
    pcall(function()
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxasset://sounds/electronicpingshort.wav"
        sound.Volume = kind == "hover" and 0.035 or 0.075
        sound.PlaybackSpeed = kind == "hover" and 1.85 or 1.35
        sound.Parent = SoundService
        sound:Play()
        Debris:AddItem(sound, 2)
    end)
end

