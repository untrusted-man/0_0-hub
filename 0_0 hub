local function safeExecute(callback, name, state)
    local scriptData
    for _, item in ipairs(ScriptLibrary) do
        if item.name == name then
            scriptData = item
            break
        end
    end
    if not scriptData then
        return false, "Unknown module"
    end

    local success, result = pcall(callback, state)
    if success and (not scriptData.isToggle or result ~= false) then
        if scriptData.isToggle then
            if state then
                HubState.ActiveScripts[name] = HubState.ActiveScripts[name] or true
                showNotification(tr("script_enabled", tr(name)), "success")
            else
                HubState.ActiveScripts[name] = nil
                showNotification(tr("script_disabled", tr(name)), "info")
            end
        else
            showNotification(tr("script_executed", tr(name)), "success")
        end
        refreshLocalization()
        return true, result
    end

    if scriptData.isToggle and state then
        HubState.ActiveScripts[name] = nil
    end
    showNotification(tr("error_occurred", tostring(result)), "error")
    refreshLocalization()
    return false, result
end

