    local function respondToAI(prompt)
        local lowered = prompt:lower()
        local script = findRequestedScript(lowered)
        local wantsDisable = containsAny(lowered, {"disable", "turn off", "switch off", "desactivar", "apagar"})
        local wantsEnable = containsAny(lowered, {"enable", "turn on", "switch on", "activar", "encender"})
        local wantsToggle = containsAny(lowered, {"toggle", "alternar"})
        local wantsExecute = containsAny(lowered, {"execute", "run ", "launch", "ejecutar", "ejecuta", "abrir", "abre"})
        local wantsExplain = containsAny(lowered, {"explain", "describe", "explica", "explicar", "describe"})
        local wantsGenerate = containsAny(lowered, {"generate", "make a", "create a", "genera", "crear", "crea un", "haz un"})

        if script and wantsExplain then
            addChatMessage("ai", function()
                return tr("ai_explanation", tr(script.name), tr(script.descriptionKey))
            end)
            return
        end

        if script and (wantsEnable or wantsDisable or wantsToggle) then
            if not script.isToggle then
                addChatMessage("ai", function()
                    return tr("ai_not_toggleable", tr(script.name))
                end)
                return
            end
            local nextState = wantsEnable or (wantsToggle and not HubState.ActiveScripts[script.name])
            if wantsDisable then
                nextState = false
            end
            local ok = safeExecute(script.func, script.name, nextState)
            if ok then
                if HubState.ScriptHistory[#HubState.ScriptHistory] ~= script.name then
                    table.insert(HubState.ScriptHistory, script.name)
                end
                addChatMessage("ai", function()
                    return tr("ai_toggle_done", tr(script.name), tr(nextState and "state_on" or "state_off"))
                end)
            end
            return
        end

        if script and wantsExecute then
            local ok = safeExecute(script.func, script.name, script.isToggle and not HubState.ActiveScripts[script.name] or false)
            if ok then
                if HubState.ScriptHistory[#HubState.ScriptHistory] ~= script.name then
                    table.insert(HubState.ScriptHistory, script.name)
                end
                addChatMessage("ai", function()
                    return tr("ai_execute_done", tr(script.name))
                end)
            end
            return
        end

        if wantsGenerate then
            local kind
            if containsAny(lowered, {"speed", "fast", "velocidad", "rápido", "rapido"}) then
                kind = "speed"
            elseif containsAny(lowered, {"jump", "salto"}) then
                kind = "jump"
            elseif containsAny(lowered, {"fly", "flight", "vuelo", "volar"}) then
                kind = "fly"
            elseif containsAny(lowered, {"noclip", "no clip", "sin colisiones", "atravesar"}) then
                kind = "noclip"
            elseif containsAny(lowered, {"health", "god", "salud", "invencible"}) then
                kind = "health"
            end
            if kind then
                local numberValue = tonumber(lowered:match("%d+"))
                addChatMessage("ai", function()
                    return tr("ai_generating_script")
                end)
                local code = generatedCode(kind, numberValue)
                addChatMessage("ai", function()
                    return code
                end, true)
                return
            end
        end

        if containsAny(lowered, {"hello", "hi", "hey", "hola", "buenas"}) then
            addChatMessage("ai", function()
                return tr("ai_greeting")
            end)
        elseif containsAny(lowered, {"help", "what can", "ayuda", "qué puedes", "que puedes"}) then
            addChatMessage("ai", function()
                return tr("ai_help")
            end)
        elseif script then
            addChatMessage("ai", function()
                return tr("ai_explanation", tr(script.name), tr(script.descriptionKey))
            end)
        elseif wantsEnable or wantsDisable or wantsToggle or wantsExecute or wantsExplain then
