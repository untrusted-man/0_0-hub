        descriptionKey = "freecam_pro_desc",
        func = function(state)
            local camera = workspace.CurrentCamera
            if not camera then
                return false
            end

            if state then
                local pitch, yaw = camera.CFrame:ToOrientation()
                local position = camera.CFrame.Position
                local keys = {}
                local looking = false
                local saved = {
                    CameraType = camera.CameraType,
                    CameraSubject = camera.CameraSubject,
                    CameraCFrame = camera.CFrame,
                    MouseBehavior = UserInputService.MouseBehavior,
                    Connections = {},
                }

                camera.CameraType = Enum.CameraType.Scriptable
                local movementKeys = {
                    [Enum.KeyCode.W] = Vector3.new(0, 0, -1),
                    [Enum.KeyCode.S] = Vector3.new(0, 0, 1),
                    [Enum.KeyCode.A] = Vector3.new(-1, 0, 0),
                    [Enum.KeyCode.D] = Vector3.new(1, 0, 0),
                    [Enum.KeyCode.Q] = Vector3.new(0, -1, 0),
                    [Enum.KeyCode.E] = Vector3.new(0, 1, 0),
                }

                saved.Connections.Began = UserInputService.InputBegan:Connect(function(input, processed)
                    if input.UserInputType == Enum.UserInputType.MouseButton2 then
                        looking = true
                        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
                        return
                    end
                    if not processed and movementKeys[input.KeyCode] then
                        keys[input.KeyCode] = true
                    end
                end)
                saved.Connections.Ended = UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton2 then
                        looking = false
                        UserInputService.MouseBehavior = saved.MouseBehavior
                        return
                    end
                    if movementKeys[input.KeyCode] then
                        keys[input.KeyCode] = nil
                    end
                end)
                saved.Connections.Render = RunService.RenderStepped:Connect(function(deltaTime)
                    if looking then
                        local mouseDelta = UserInputService:GetMouseDelta()
                        yaw -= mouseDelta.X * 0.0028
                        pitch = math.clamp(pitch - mouseDelta.Y * 0.0028, -1.5, 1.5)
                    end

                    local localMovement = Vector3.zero
                    for keyCode, direction in pairs(movementKeys) do
                        if keys[keyCode] then
                            localMovement += direction
                        end
                    end
                    if localMovement.Magnitude > 1 then
                        localMovement = localMovement.Unit
                    end
                    local rotation = CFrame.fromOrientation(pitch, yaw, 0)
                    local speed = keys[Enum.KeyCode.LeftShift] and 180 or 55
                    position += rotation:VectorToWorldSpace(localMovement) * speed * deltaTime
                    camera.CFrame = CFrame.new(position) * rotation
                end)
                saved.Connections.ShiftBegan = UserInputService.InputBegan:Connect(function(input, processed)
                    if not processed and input.KeyCode == Enum.KeyCode.LeftShift then
                        keys[Enum.KeyCode.LeftShift] = true
                    end
                end)
                saved.Connections.ShiftEnded = UserInputService.InputEnded:Connect(function(input)
                    if input.KeyCode == Enum.KeyCode.LeftShift then
                        keys[Enum.KeyCode.LeftShift] = nil
                    end
                end)

                HubState.ActiveScripts.freecam_pro = saved
                showNotification(tr("freecam_hint"), "info")
                return true
            end

            local saved = HubState.ActiveScripts.freecam_pro
            if saved then
                for _, connection in pairs(saved.Connections or {}) do
                    if connection and connection.Connected then
                        connection:Disconnect()
                    end
                end
                UserInputService.MouseBehavior = saved.MouseBehavior or Enum.MouseBehavior.Default
                pcall(function()
                    camera.CameraType = saved.CameraType
                    camera.CameraSubject = saved.CameraSubject
                    camera.CFrame = saved.CameraCFrame
                end)
                HubState.ActiveScripts.freecam_pro = nil
            end
            return true
        end,
